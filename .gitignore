# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore
# Mirrors accxui sibling apps (job-manager, transfers) — keep in sync.

*~
*.sw[mnpcod]
.tmp
*.tmp
*.tmp.*
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
UserInterfaceState.xcuserstate
$RECYCLE.BIN/

*.log
log.txt
npm-debug.log*

/.tmp
/tmp
/.idea
/.ionic
/.sass-cache
/.sourcemaps
/.versions
/.vscode
/coverage
/dist
/node_modules
/platforms
/plugins
/www

# Secrets — credentials live here in .env.local. NEVER commit.
.env
.env.*
!.env.example

.history
.firebase
.gradle
/.claude
/.gstack
.gstack/
